_DOMAIN_ {
  _TLS_

  encode zstd gzip

  root * _ROOT_

  # Long-cache the static asset extensions (was nginx `expires max`).
  @static path *.ogg *.ogv *.svg *.svgz *.eot *.otf *.woff *.woff2 *.mp4 *.ttf *.css *.rss *.atom *.js *.json *.jpg *.jpeg *.gif *.png *.ico *.zip *.tgz *.gz *.rar *.bz2 *.doc *.xls *.ppt *.tar *.mid *.midi *.wav *.bmp *.rtf

  # (a) file exists in the repo public root -> serve it (+ cache if static).
  @repoFile file
  handle @repoFile {
    header @static Cache-Control "public, max-age=31536000, immutable"
    file_server
  }

  # (b) else it exists in the external static/uploads folder -> serve from there.
  @extFile file {
    root _STATIC_FILES_
    try_files {path}
  }
  handle @extFile {
    root * _STATIC_FILES_
    header @static Cache-Control "public, max-age=31536000, immutable"
    file_server
  }

  # (c) else -> the Swoole app. Host is preserved (the redirect middleware
  # matches on it); X-Forwarded-For/Proto are added automatically; WebSockets
  # (the reload channel) proxy transparently.
  handle {
    reverse_proxy 127.0.0.1:_PORT_ {
      header_up Host {host}
      # Blue/green later: add a second node + active health check here, e.g.
      #   reverse_proxy 127.0.0.1:_PORT_ 127.0.0.1:8212 {
      #     lb_policy round_robin
      #     health_uri /health   health_interval 3s   fail_duration 15s
    }
  }
}
